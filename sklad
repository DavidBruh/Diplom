&НаСервере
Функция ПроанализироватьОстаткиНаСервере(Склад, ИсторияJSON)

	ЗапросОстатки = Новый Запрос;
	Если ЗначениеЗаполнено(Склад) Тогда
		ЗапросОстатки.Текст =
			"ВЫБРАТЬ
			|	ОстаткиНоменклатурыОстатки.Номенклатура КАК Номенклатура,
			|	ОстаткиНоменклатурыОстатки.Склад КАК Склад,
			|	ОстаткиНоменклатурыОстатки.КоличествоОстаток КАК Количество
			|ИЗ
			|	РегистрНакопления.ОстаткиНоменклатуры.Остатки(, Склад = &Склад) КАК ОстаткиНоменклатурыОстатки
			|УПОРЯДОЧИТЬ ПО
			|	Номенклатура";
		ЗапросОстатки.УстановитьПараметр("Склад", Склад);
	Иначе
		ЗапросОстатки.Текст =
			"ВЫБРАТЬ
			|	ОстаткиНоменклатурыОстатки.Номенклатура КАК Номенклатура,
			|	ОстаткиНоменклатурыОстатки.Склад КАК Склад,
			|	ОстаткиНоменклатурыОстатки.КоличествоОстаток КАК Количество
			|ИЗ
			|	РегистрНакопления.ОстаткиНоменклатуры.Остатки() КАК ОстаткиНоменклатурыОстатки
			|УПОРЯДОЧИТЬ ПО
			|	Номенклатура";
	КонецЕсли;

	ОстаткиТаблица = ЗапросОстатки.Выполнить().Выгрузить();

	Если ОстаткиТаблица.Количество() = 0 Тогда
		Результат = Новый Структура;
		Результат.Вставить("Ответ", "Остатки не найдены.");
		Результат.Вставить("История", ИсторияJSON);
		Результат.Вставить("ТоварыДляЗаказа", "");
		Возврат Результат;
	КонецЕсли;

	ДатаНач = ТекущаяДата() - 30 * 24 * 60 * 60;
	ДатаКон = ТекущаяДата();

	ЗапросПродажи = Новый Запрос;
	ЗапросПродажи.Текст =
		"ВЫБРАТЬ
		|	Продажи.Товар КАК Номенклатура,
		|	СУММА(Продажи.Количество) КАК КоличествоПродано
		|ИЗ
		|	РегистрНакопления.Продажи КАК Продажи
		|ГДЕ
		|	Продажи.Период МЕЖДУ &ДатаНач И &ДатаКон
		|СГРУППИРОВАТЬ ПО
		|	Продажи.Товар";
	ЗапросПродажи.УстановитьПараметр("ДатаНач", ДатаНач);
	ЗапросПродажи.УстановитьПараметр("ДатаКон", ДатаКон);
	ПродажиТаблица = ЗапросПродажи.Выполнить().Выгрузить();

	ПродажиСоответствие = Новый Соответствие;
	Для Каждого Строка Из ПродажиТаблица Цикл
		ПродажиСоответствие.Вставить(Строка.Номенклатура, Строка.КоличествоПродано);
	КонецЦикла;

	ЗапросРасходМатериалов = Новый Запрос;
	ЗапросРасходМатериалов.Текст =
		"ВЫБРАТЬ
		|	ОстаткиНоменклатурыОбороты.Номенклатура КАК Номенклатура,
		|	СУММА(ОстаткиНоменклатурыОбороты.КоличествоРасход) КАК КоличествоИзрасходовано
		|ИЗ
		|	РегистрНакопления.ОстаткиНоменклатуры.Обороты(
		|		&ДатаНач, &ДатаКон, , ) КАК ОстаткиНоменклатурыОбороты
		|ГДЕ
		|	ОстаткиНоменклатурыОбороты.КоличествоРасход > 0
		|СГРУППИРОВАТЬ ПО
		|	ОстаткиНоменклатурыОбороты.Номенклатура";
	ЗапросРасходМатериалов.УстановитьПараметр("ДатаНач", ДатаНач);
	ЗапросРасходМатериалов.УстановитьПараметр("ДатаКон", ДатаКон);
	РасходМатериаловТаблица = ЗапросРасходМатериалов.Выполнить().Выгрузить();

	РасходМатериаловСоответствие = Новый Соответствие;
	Для Каждого Строка Из РасходМатериаловТаблица Цикл
		РасходМатериаловСоответствие.Вставить(Строка.Номенклатура, Строка.КоличествоИзрасходовано);
	КонецЦикла;

	НазваниеСклада = ?(ЗначениеЗаполнено(Склад), Строка(Склад), "всем складам");
	ТекстДанных =
		"=== АНАЛИЗ ТОВАРНЫХ ЗАПАСОВ по " + НазваниеСклада + " ===" + Символы.ПС +
		"Период анализа продаж: последние 30 дней." + Символы.ПС + Символы.ПС;

	ТоварыДляЗаказа = Новый Массив;

	Для Каждого Строка Из ОстаткиТаблица Цикл
		КоличествоПродано = ПродажиСоответствие[Строка.Номенклатура];
		Если КоличествоПродано = Неопределено Тогда
			КоличествоПродано = 0;
		КонецЕсли;
		СреднедневныеПродажи = КоличествоПродано / 30;
		Если СреднедневныеПродажи > 0 Тогда
			ЗапасДней = Окр(Строка.Количество / СреднедневныеПродажи, 0);
		Иначе
			ЗапасДней = -1;
		КонецЕсли;
		ТекстДанных = ТекстДанных +
			"Товар: " + Строка(Строка.Номенклатура) + Символы.ПС +
			"  Остаток: " + Строка(Строка.Количество) + " шт." + Символы.ПС +
			"  Продано за 30 дней: " + Строка(КоличествоПродано) + " шт." + Символы.ПС +
			"  Среднедневные продажи: " + Строка(Окр(СреднедневныеПродажи, 2)) + " шт./день" + Символы.ПС +
			?(ЗапасДней >= 0,
				"  Запас хватит примерно на: " + Строка(ЗапасДней) + " дней" + Символы.ПС,
				"  Продаж не было — товар не двигался" + Символы.ПС) +
			Символы.ПС;
		Если СреднедневныеПродажи > 0 И ЗапасДней <= 14 Тогда
			ЭлементЗаказа = Новый Структура;
			ЭлементЗаказа.Вставить("Номенклатура", Строка(Строка.Номенклатура));
			РекомендуемоеКоличество = Окр(СреднедневныеПродажи * 30 - Строка.Количество, 0);
			Если РекомендуемоеКоличество < 0 Тогда
				РекомендуемоеКоличество = 0;
			КонецЕсли;
			ЭлементЗаказа.Вставить("Количество", РекомендуемоеКоличество);
			ЭлементЗаказа.Вставить("ЗапасДней", ЗапасДней);
			ТоварыДляЗаказа.Добавить(ЭлементЗаказа);
		КонецЕсли;
	КонецЦикла;

	ТекстДанных = ТекстДанных +
		"=== АНАЛИЗ ОСТАТКОВ МАТЕРИАЛОВ ДЛЯ УСЛУГ ===" + Символы.ПС +
		"Период анализа расхода: последние 30 дней." + Символы.ПС + Символы.ПС;

	Для Каждого Строка Из ОстаткиТаблица Цикл
		КоличествоИзрасходовано = РасходМатериаловСоответствие[Строка.Номенклатура];
		Если КоличествоИзрасходовано = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		СреднедневныйРасход = КоличествоИзрасходовано / 30;
		Если СреднедневныйРасход > 0 Тогда
			ЗапасДней = Окр(Строка.Количество / СреднедневныйРасход, 0);
		Иначе
			ЗапасДней = -1;
		КонецЕсли;
		ТекстДанных = ТекстДанных +
			"Материал: " + Строка(Строка.Номенклатура) + Символы.ПС +
			"  Остаток: " + Строка(Строка.Количество) + " шт." + Символы.ПС +
			"  Израсходовано за 30 дней: " + Строка(КоличествоИзрасходовано) + " шт." + Символы.ПС +
			"  Среднедневной расход: " + Строка(Окр(СреднедневныйРасход, 2)) + " шт./день" + Символы.ПС +
			?(ЗапасДней >= 0,
				"  Запаса хватит примерно на: " + Строка(ЗапасДней) + " дней" + Символы.ПС,
				"  Расхода не было" + Символы.ПС) +
			Символы.ПС;
		Если ЗапасДней >= 0 И ЗапасДней <= 14 Тогда
			ЭлементЗаказа = Новый Структура;
			ЭлементЗаказа.Вставить("Номенклатура", Строка(Строка.Номенклатура));
			РекомендуемоеКоличество = Окр(СреднедневныйРасход * 30 - Строка.Количество, 0);
			Если РекомендуемоеКоличество < 0 Тогда
				РекомендуемоеКоличество = 0;
			КонецЕсли;
			ЭлементЗаказа.Вставить("Количество", РекомендуемоеКоличество);
			ЭлементЗаказа.Вставить("ЗапасДней", ЗапасДней);
			ТоварыДляЗаказа.Добавить(ЭлементЗаказа);
		КонецЕсли;
	КонецЦикла;

	СистемныйПромт =
		"Ты — аналитик склада. Тебе дают реальные данные об остатках из 1С." + Символы.ПС +
		"Данные разделены на два блока: товары для продажи и материалы для оказания услуг." + Символы.ПС +
		"Проанализируй каждый блок отдельно и дай конкретные рекомендации:" + Символы.ПС +
		"- Запас менее 7 дней — критическая ситуация, срочный заказ." + Символы.ПС +
		"- Запас 7-14 дней — требуют внимания, заказ в ближайшее время." + Символы.ПС +
		"- Запас более 60 дней — возможный избыток." + Символы.ПС +
		"- Не продавались/не расходовались 30 дней — отметить отдельно." + Символы.ПС +
		"- Для критических позиций указывай: остаток, расход в день, запас в днях." + Символы.ПС +
		"- В конце если есть позиции с запасом менее 14 дней — добавь блок:" + Символы.ПС +
		"  'ТРЕБУЕТСЯ ПОПОЛНЕНИЕ: откройте документ Заказ номенклатуры.'" + Символы.ПС +
		"  И перечисли позиции с рекомендуемым количеством к заказу на 30 дней вперёд." + Символы.ПС +
		"Отвечай структурированно, используй эмодзи. Будь конкретен — называй позиции и цифры.";

	Сообщения = Новый Массив;

	СистемноеСообщение = Новый Структура;
	СистемноеСообщение.Вставить("role", "system");
	СистемноеСообщение.Вставить("text", СистемныйПромт);
	Сообщения.Добавить(СистемноеСообщение);

	Если НЕ ПустаяСтрока(ИсторияJSON) Тогда
		ЧтениеИстории = Новый ЧтениеJSON;
		ЧтениеИстории.УстановитьСтроку(ИсторияJSON);
		История = ПрочитатьJSON(ЧтениеИстории);
		Для Каждого Сообщение Из История Цикл
			Сообщения.Добавить(Сообщение);
		КонецЦикла;
	КонецЕсли;

	НовоеСообщение = Новый Структура;
	НовоеСообщение.Вставить("role", "user");
	НовоеСообщение.Вставить("text", ТекстДанных);
	Сообщения.Добавить(НовоеСообщение);

	ТекстОтвета = ОтправитьЗапросВЯндексГПТ(Сообщения);

	ЗаписьТоваров = Новый ЗаписьJSON;
	ЗаписьТоваров.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьТоваров, ТоварыДляЗаказа);

	Результат = Новый Структура;
	Результат.Вставить("Ответ", ТекстОтвета);
	Результат.Вставить("История", СохранитьИсторию(ИсторияJSON, НовоеСообщение, ТекстОтвета));
	Результат.Вставить("ТоварыДляЗаказа", ЗаписьТоваров.Закрыть());
	Возврат Результат;

КонецФункции
