// Модуль объекта документа "РасходныйКассовыйОрдер"

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка) 

    // Документ вводится на основании "ПриходнаяНакладная"
    Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
        
        // Чтобы система не пыталась сама что-то заполнять
        СтандартнаяОбработка = Ложь;

        // Заполнение шапки
        Получил   = ДанныеЗаполнения.Поставщик;  // кому платим
        Основание = ДанныеЗаполнения.Ссылка;     // ссылка на накладную

        // Считаем общую сумму по табличной части "Приход"
        Суммирование = 0;
        Для каждого ТекСтрокаПриход Из ДанныеЗаполнения.Приход Цикл
            Суммирование = Суммирование + ТекСтрокаПриход.Сумма;
        КонецЦикла;

        Сумма = Суммирование;

    КонецЕсли;

КонецПроцедуры


Процедура ОбработкаПроведения(Отказ, Режим)

    // --- Регистр накопления "ДенежныеСредства": выдача денег из кассы ---

    Движения.ДенежныеСредства.Записывать = Истина;

    ДвижениеДС = Движения.ДенежныеСредства.Добавить();
    ДвижениеДС.ВидДвижения = ВидДвиженияНакопления.Расход;
    ДвижениеДС.Период      = Дата;
    ДвижениеДС.Основание   = Основание;
    ДвижениеДС.Сумма       = Сумма;


    // --- Регистр бухгалтерии "Управленческий": Дт 60 Кт 50 ---

    Движения.Управленческий.Записывать = Истина;

    ДвижениеБух = Движения.Управленческий.Добавить();
    ДвижениеБух.Период = Дата;

    // Дебет 60 "Поставщики и подрядчики"
    ДвижениеБух.СчетДт = ПланыСчетов.Основной.ПоставщикиИПодрядчики;

    // Кредит 50 "Касса"
    ДвижениеБух.СчетКт = ПланыСчетов.Основной.Касса;

    // Сумма оплаты
    ДвижениеБух.Сумма = Сумма;

    // Субконто по дебету — Поставщик (получатель денег)
    ДвижениеБух.СубконтоДт[
        ПланыВидовХарактеристик.ВидыСубконто.Поставщики] = Получил;

    // По кредиту 50 субконто обычно нет — ничего не задаём

КонецПроцедуры
