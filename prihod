Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ТоварныйЧек") Тогда
		Сдал = ДанныеЗаполнения.Продавец;
		Основание = ДанныеЗаполнения.Ссылка;
		Суммирование = 0;
		Для каждого ТекСтрокаПродажи из ДанныеЗаполнения.Продажи Цикл
			Суммирование = Суммирование + ТекСтрокаПродажи.ИтоговаяСумма;
		КонецЦикла;
		Сумма = Суммирование;
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОказаниеУслуг") Тогда
		Сдал = ДанныеЗаполнения.Мастер;
		Основание = ДанныеЗаполнения.Ссылка; 
		Суммирование = 0;
		Для каждого ТекСтрокаПродажи из ДанныеЗаполнения.Услуги Цикл
			Суммирование = Суммирование + ТекСтрокаПродажи.ИтоговаяСумма;
		КонецЦикла;  
		Для каждого ТекСтрокаПродажи из ДанныеЗаполнения.Материалы Цикл
			Суммирование = Суммирование + ТекСтрокаПродажи.Сумма;
		КонецЦикла;
		Сумма = Суммирование;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)

	Движения.ДенежныеСредства.Записывать = Истина;
	Движения.Управленческий.Записывать = Истина;

	Движение = Движения.ДенежныеСредства.Добавить();
	Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
	Движение.Период = Дата;
	Движение.Основание = Основание;
	Движение.Сумма = Сумма;

	ДвижениеБух = Движения.Управленческий.Добавить();
	ДвижениеБух.Период = Дата;
	ДвижениеБух.СчетДт = ПланыСчетов.Основной.Касса;                // 50
	ДвижениеБух.СчетКт = ПланыСчетов.Основной.ПокупателиИЗаказчики; // 62
	ДвижениеБух.Сумма = Сумма;

КонецПроцедуры
