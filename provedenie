Процедура ОбработкаПроведения(Отказ, Режим)

	Движения.ОстаткиНоменклатуры.Записывать = Истина; 
	Движения.Продажи.Записывать = Истина;
	Движения.Управленческий.Записывать = Истина;

	Для Каждого ТекСтрокаПродажи Из Продажи Цикл

		Движение = Движения.ОстаткиНоменклатуры.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Номенклатура = ТекСтрокаПродажи.Товар;
		Движение.Склад = Склад;
		Движение.Количество = ТекСтрокаПродажи.Количество;

		Движение = Движения.Продажи.Добавить();
		Движение.Период = Дата;
		Движение.Товар = ТекСтрокаПродажи.Товар;
		Движение.Продавец = Продавец;
		Движение.Количество = ТекСтрокаПродажи.Количество;
		Движение.Сумма = ТекСтрокаПродажи.ИтоговаяСумма;

		ЗапросЦена = Новый Запрос;
		ЗапросЦена.Текст =
			"ВЫБРАТЬ
			|	ЦеныПрихода.Цена КАК Цена
			|ИЗ
			|	РегистрСведений.ЦеныПрихода КАК ЦеныПрихода
			|ГДЕ
			|	ЦеныПрихода.Номенклатура = &Номенклатура";
		ЗапросЦена.УстановитьПараметр("Номенклатура", ТекСтрокаПродажи.Товар);
		ВыборкаЦена = ЗапросЦена.Выполнить().Выбрать();
		СебестоимостьСтроки = 0;
		Если ВыборкаЦена.Следующий() Тогда
			СебестоимостьСтроки = ВыборкаЦена.Цена * ТекСтрокаПродажи.Количество;
		КонецЕсли;

		ДвижениеБух = Движения.Управленческий.Добавить();
		ДвижениеБух.Период = Дата;
		ДвижениеБух.СчетДт = ПланыСчетов.Основной.ПокупателиИЗаказчики; // 62
		ДвижениеБух.СчетКт = ПланыСчетов.Основной.Выручка;              // 90.1
		ДвижениеБух.Сумма = ТекСтрокаПродажи.ИтоговаяСумма;

		ДвижениеБух = Движения.Управленческий.Добавить();
		ДвижениеБух.Период = Дата;
		ДвижениеБух.СчетДт = ПланыСчетов.Основной.СебестоимостьПродаж;  // 90.2
		ДвижениеБух.СчетКт = ПланыСчетов.Основной.Товары;               // 41
		ДвижениеБух.Сумма = СебестоимостьСтроки;
		ДвижениеБух.СубконтоКт[
			ПланыВидовХарактеристик.ВидыСубконто.Товары] = ТекСтрокаПродажи.Товар;

	КонецЦикла;

	Движения.Записать();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОстаткиНоменклатурыОстатки.КоличествоОстаток КАК КоличествоОстаток,
		|	ОстаткиНоменклатурыОстатки.Номенклатура КАК Номенклатура
		|ИЗ
		|	РегистрНакопления.ОстаткиНоменклатуры.Остатки(
		|			,
		|			Склад = &Склад
		|				И Номенклатура В (&МассивТоваров)) КАК ОстаткиНоменклатурыОстатки
		|ГДЕ
		|	ОстаткиНоменклатурыОстатки.КоличествоОстаток < 0";

	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("МассивТоваров", Продажи.ВыгрузитьКолонку("Товар"));

	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда   
		Отказ = Истина;
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			Сообщить("На складе " + Склад + " не хватает " + 
				Выборка.КоличествоОстаток * (-1) + " шт. товаров " + Выборка.Номенклатура);
		КонецЦикла;
	КонецЕсли;

	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	КонецЦикла;

КонецПроцедуры
