Перем ПорогОстатка;

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПорогОстатка = 7; 
КонецПроцедуры

&НаКлиенте
Процедура ПродажиСкидкаПриИзменении(Элемент)
	Стч = Элементы.Продажи.ТекущиеДанные;
	Стч.РазмерСкидки = РаботаСоСкидкой.ПолучитьСкидку(Стч.Скидка);
	Стч.СуммаСкидки   = Стч.Количество * Стч.Цена * Стч.РазмерСкидки / 100;
	Стч.ИтоговаяСумма = Стч.Количество * Стч.Цена - Стч.СуммаСкидки;
КонецПроцедуры

&НаКлиенте
Процедура ПродажиКоличествоПриИзменении(Элемент)
	Стч = Элементы.Продажи.ТекущиеДанные;
	Стч.СуммаСкидки   = Стч.Количество * Стч.Цена * Стч.РазмерСкидки / 100;
	Стч.ИтоговаяСумма = Стч.Количество * Стч.Цена - Стч.СуммаСкидки;
КонецПроцедуры

// Объединённая процедура: цена + пересчёт сумм + проверка остатка
&НаКлиенте
Процедура ПродажиТоварПриИзменении(Элемент)

	Стч = Элементы.Продажи.ТекущиеДанные;
	Если Стч = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Стч.Товар) Тогда
		Возврат;
	КонецЕсли;

	// Получаем цену и пересчитываем суммы
	Стч.Цена          = РаботаСЦенами.ЦенаПродажи(Объект.Дата, Стч.Товар);
	Стч.СуммаСкидки   = Стч.Количество * Стч.Цена * Стч.РазмерСкидки / 100;
	Стч.ИтоговаяСумма = Стч.Количество * Стч.Цена - Стч.СуммаСкидки;

	// Проверяем остаток на сервере
	РезультатПроверки = ПроверитьОстатокТовараНаСервере(
		Стч.Товар,
		Объект.Склад
	);

	Если РезультатПроверки.ЕстьПредупреждение Тогда
		ПоказатьПредупреждение(
			Новый ОписаниеОповещения("ПослеПредупреждения", ЭтотОбъект, Стч.Товар),
			РезультатПроверки.Сообщение,
			,
			"⚠️ Внимание: низкий остаток!"
		);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПослеПредупреждения(ВыбранноеДействие, Товар) Экспорт
	// Здесь можно добавить открытие документа Заказ номенклатуры
КонецПроцедуры

&НаСервере
Функция ПроверитьОстатокТовараНаСервере(Товар, Склад)

	Результат = Новый Структура("ЕстьПредупреждение, Сообщение", Ложь, "");

	// Получаем текущий остаток
	ЗапросОстаток = Новый Запрос;
	Если ЗначениеЗаполнено(Склад) Тогда
		ЗапросОстаток.Текст =
			"ВЫБРАТЬ
			|	ЕСТЬNULL(ОстаткиНоменклатурыОстатки.КоличествоОстаток, 0) КАК Остаток
			|ИЗ
			|	РегистрНакопления.ОстаткиНоменклатуры.Остатки(
			|		, Номенклатура = &Товар И Склад = &Склад) КАК ОстаткиНоменклатурыОстатки";
		ЗапросОстаток.УстановитьПараметр("Склад", Склад);
	Иначе
		ЗапросОстаток.Текст =
			"ВЫБРАТЬ
			|	ЕСТЬNULL(СУММА(ОстаткиНоменклатурыОстатки.КоличествоОстаток), 0) КАК Остаток
			|ИЗ
			|	РегистрНакопления.ОстаткиНоменклатуры.Остатки(
			|		, Номенклатура = &Товар) КАК ОстаткиНоменклатурыОстатки";
	КонецЕсли;
	ЗапросОстаток.УстановитьПараметр("Товар", Товар);

	ВыборкаОстаток = ЗапросОстаток.Выполнить().Выбрать();
	ВыборкаОстаток.Следующий();
	ТекущийОстаток = ВыборкаОстаток.Остаток;

	// Получаем продажи за последние 30 дней
	ДатаНач = ТекущаяДата() - 30 * 24 * 60 * 60;

	ЗапросПродажи = Новый Запрос;
	ЗапросПродажи.Текст =
		"ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(Продажи.Количество), 0) КАК КоличествоПродано
		|ИЗ
		|	РегистрНакопления.Продажи КАК Продажи
		|ГДЕ
		|	Продажи.Товар = &Товар
		|	И Продажи.Период >= &ДатаНач";
	ЗапросПродажи.УстановитьПараметр("Товар", Товар);
	ЗапросПродажи.УстановитьПараметр("ДатаНач", ДатаНач);

	ВыборкаПродажи = ЗапросПродажи.Выполнить().Выбрать();
	ВыборкаПродажи.Следующий();
	КоличествоПродано = ВыборкаПродажи.КоличествоПродано;

	// Считаем запас в днях
	Если КоличествоПродано > 0 Тогда
		СреднедневныеПродажи = КоличествоПродано / 30;
		ЗапасДней = Окр(ТекущийОстаток / СреднедневныеПродажи, 0);
	Иначе
		Если ТекущийОстаток <= 3 Тогда
			Результат.ЕстьПредупреждение = Истина;
			Результат.Сообщение =
				"Товар: " + Строка(Товар) + Символы.ПС +
				"Текущий остаток: " + Строка(ТекущийОстаток) + " шт." + Символы.ПС +
				"За последние 30 дней продаж не было." + Символы.ПС +
				"Рекомендуется проверить актуальность остатка.";
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;

	Если ЗапасДней <= 7 Тогда
		Результат.ЕстьПредупреждение = Истина;
		Результат.Сообщение =
			"⚠️ Товар: " + Строка(Товар) + Символы.ПС + Символы.ПС +
			"Текущий остаток: " + Строка(ТекущийОстаток) + " шт." + Символы.ПС +
			"Продано за 30 дней: " + Строка(КоличествоПродано) + " шт." + Символы.ПС +
			"Среднедневные продажи: " + Строка(Окр(СреднедневныеПродажи, 2)) + " шт./день" + Символы.ПС +
			"Запасов хватит примерно на: " + Строка(ЗапасДней) + " дней" + Символы.ПС + Символы.ПС +
			"Рекомендуется пополнить запасы!";
	КонецЕсли;

	Возврат Результат;

КонецФункции
